# Copie para .env.local e preencha. NUNCA versione o .env.local (está no .gitignore).

# Supabase — projeto em https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
# Só servidor — nunca expor no browser. Usada em rotas/admin (ex: confirmar inscrição anônima).
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Brevo — e-mail transacional (ingresso). https://app.brevo.com → SMTP & API → API Keys
# A chave começa com "xkeysib-". O remetente precisa ser um sender verificado no Brevo.
BREVO_API_KEY=xkeysib-sua-key
BREVO_FROM_EMAIL=ingressos@seu-dominio.com.br
BREVO_FROM_NAME=Creden

# URL pública do app (para montar links de ingresso nos e-mails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
